{
  // Self-contained: the framework is a node_modules dependency now, not a
  // vendored storage/framework/core to extend. @stacksjs/* resolve from
  // node_modules (they ship .d.ts); skipLibCheck keeps typecheck on this app's
  // own code rather than the framework's shipped declarations.
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun"],
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "Actions/*": ["./app/Actions/*"],
      "Commands/*": ["./app/Commands/*"],
      "Jobs/*": ["./app/Jobs/*"],
      "Middleware/*": ["./app/Middleware/*"],
      "Models/*": ["./app/Models/*"],
      "Notifications/*": ["./app/Notifications/*"],
      "~/*": ["./*"],
      "@/*": ["./resources/*"]
    }
  },
  "include": [
    "*.ts",
    "app/Actions/**/*.ts",
    "*.d.ts",
    "app/Models/**/*.ts",
    "app/Services/**/*.ts",
    "app/Support/**/*.ts"
  ],
  "exclude": [
    "cloud/**",
    "dist/**",
    "node_modules/**",
    "pantry/**",
    "storage/framework/**",
    "resources/assets/**"
  ]
}
