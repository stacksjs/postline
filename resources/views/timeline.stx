<script server>
const timelineItems = [
  {
    author: 'jay.bsky.social',
    label: 'Design systems',
    text: 'The best writing tools stay out of the way until you need structure.',
    meta: '42 likes / 8 reposts',
  },
  {
    author: 'maya.bsky.social',
    label: 'Indie tools',
    text: 'Scheduling is really a promise to your future self. Good software makes the promise easy to keep.',
    meta: '128 likes / 21 replies',
  },
  {
    author: 'chris.bsky.social',
    label: 'Postline',
    text: 'Postline now has its first driver shape: Bluesky publish and timeline methods, with room for the rest.',
    meta: 'Draft preview',
  },
]

const streams = [
  { label: 'Home', value: 'Bluesky', state: 'Live' },
  { label: 'Mentions', value: '@stacksjs.com', state: 'Quiet' },
  { label: 'Saved', value: 'Design systems', state: '12' },
]
</script>

@section('content')
  <section class="grid gap-4" data-postline-page="timeline" data-testid="timeline-page">
    <header class="flex flex-wrap gap-3 items-center justify-between min-h-9">
      <div>
        <p class="m-0 font-medium text-[14px] text-zinc-500">Timeline</p>
      </div>
      <div class="flex gap-2 items-center">
        <button class="inline-flex items-center justify-center h-9 w-9 text-neutral-950 bg-white border border-zinc-200 rounded-xl shadow-sm" type="button" aria-label="Refresh timeline" title="Refresh timeline" data-bluesky-timeline-refresh>
          <span class="h-4 w-4 i-hugeicons-refresh" aria-hidden="true"></span>
        </button>
        <button class="inline-flex gap-2 items-center justify-center px-4 h-9 font-bold text-sm text-white bg-neutral-950 rounded-xl" type="button">
          <span class="h-4 w-4 i-hugeicons-message-add-01" aria-hidden="true"></span>
          <span>Reply</span>
        </button>
      </div>
    </header>

    <div class="hidden px-3 py-2 text-emerald-700 text-red-700 text-sm text-zinc-600 bg-emerald-50 bg-red-50 bg-slate-50 border border-emerald-200 border-red-200 border-zinc-200 rounded-xl" role="status" data-bluesky-timeline-status></div>

    <div class="grid gap-3.5 lg:grid-cols-[minmax(0,1fr)_300px]">
      <section class="grid gap-2.5" aria-label="Bluesky timeline" data-bluesky-timeline-list>
        @foreach (timelineItems as item)
          <article class="p-3.5 bg-white border border-zinc-200 rounded-2xl shadow-sm">
