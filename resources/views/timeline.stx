              <button class="inline-flex gap-1.5 items-center justify-center px-2.5 h-8 font-bold text-neutral-950 text-xs bg-white border border-zinc-200 rounded-lg shadow-sm" type="button">
                <span class="h-3.5 w-3.5 i-hugeicons-message-01" aria-hidden="true"></span>
                <span>Reply</span>
              </button>
            </header>
            <p class="m-0 leading-normal text-[13px] text-slate-700">{{ item.text }}</p>
            <footer class="mt-3 text-xs text-zinc-500">{{ item.meta }}</footer>
          </article>
        @endforeach
      </section>

      <aside class="grid content-start gap-3.5">
        <section class="bg-white border border-zinc-200 rounded-2xl shadow-sm">
          <header class="p-3.5 border-b border-zinc-200">
            <strong class="text-[13px]">Streams</strong>
          </header>
          <div class="grid gap-2 p-3">
            @foreach (streams as stream)
              <article class="flex items-center justify-between p-2.5 bg-zinc-50 border border-zinc-200 rounded-xl">
                <span class="grid gap-0.5">
                  <strong class="text-xs">{{ stream.label }}</strong>
                  <span class="text-[11px] text-zinc-500">{{ stream.value }}</span>
                </span>
                <span class="text-xs text-zinc-500">{{ stream.state }}</span>
              </article>
            @endforeach
          </div>
        </section>

        <section class="bg-white border border-zinc-200 rounded-2xl shadow-sm">
          <header class="p-3.5 border-b border-zinc-200">
            <strong class="text-[13px]">Filters</strong>
          </header>
          <div class="flex flex-wrap gap-2 p-3">
            <button class="px-2.5 h-8 text-xs text-neutral-950 bg-zinc-100 rounded-full" type="button">Links</button>
            <button class="px-2.5 h-8 text-xs text-neutral-950 bg-zinc-100 rounded-full" type="button">Replies</button>
            <button class="px-2.5 h-8 text-xs text-neutral-950 bg-zinc-100 rounded-full" type="button">Mentions</button>
          </div>
        </section>
      </aside>
    </div>
  </section>

  <script>
    ;(() => {
      const root = document.querySelector('[data-testid="timeline-page"]')
      if (!root) return

      const button = root.querySelector('[data-bluesky-timeline-refresh]')
      const list = root.querySelector('[data-bluesky-timeline-list]')
      const status = root.querySelector('[data-bluesky-timeline-status]')

      const setStatus = (message, tone = 'neutral') => {
        if (!status) return
        status.textContent = message
        status.classList.remove('hidden', 'border-emerald-200', 'bg-emerald-50', 'text-emerald-700', 'border-red-200', 'bg-red-50', 'text-red-700', 'border-zinc-200', 'bg-slate-50', 'text-zinc-600')
        if (tone === 'success') status.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-700')
        else if (tone === 'error') status.classList.add('border-red-200', 'bg-red-50', 'text-red-700')
        else status.classList.add('border-zinc-200', 'bg-slate-50', 'text-zinc-600')
      }

      const escapeHtml = (value) => String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;')

      const renderItems = (items) => {
        if (!list || !Array.isArray(items)) return
        list.innerHTML = items.map(item => `
          <article class="p-3.5 bg-white border border-zinc-200 rounded-2xl shadow-sm">
            <header class="flex gap-3 items-center justify-between mb-3">
              <div>
                <span class="block font-bold text-xs">${escapeHtml(item.authorHandle)}</span>
                <span class="text-xs text-zinc-500">${escapeHtml(item.authorName || 'Bluesky')}</span>
              </div>
              <a class="inline-flex items-center justify-center px-3 h-8 font-bold text-neutral-950 text-xs bg-white border border-zinc-200 rounded-lg shadow-sm" href="https://bsky.app/profile/${encodeURIComponent(item.authorHandle)}" target="_blank" rel="noreferrer">Open</a>
            </header>
            <p class="m-0 leading-normal text-[13px] text-slate-700 whitespace-pre-wrap">${escapeHtml(item.body)}</p>
            <footer class="mt-3 text-xs text-zinc-500">${item.likeCount} likes / ${item.repostCount} reposts / ${item.replyCount} replies</footer>
          </article>
        `).join('')
      }

      const refresh = async () => {
        button?.setAttribute('disabled', 'disabled')
        setStatus('Syncing Bluesky timeline...')

        try {
          const response = await fetch('/api/postline/bluesky/timeline?limit=30')
          const payload = await response.json()
          if (!response.ok || !payload.ok) throw new Error(payload.error || 'Bluesky timeline sync failed.')
          renderItems(payload.data.items)
          setStatus(`Synced ${payload.data.saved} timeline posts.`, 'success')
        }
        catch (error) {
          setStatus(error instanceof Error ? error.message : String(error), 'error')
        }
        finally {
          button?.removeAttribute('disabled')
        }
      }

      button?.addEventListener('click', refresh)
    })()
  </script>
@endsection
