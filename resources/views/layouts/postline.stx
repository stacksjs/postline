<!DOCTYPE html>
<html lang="en" class="text-neutral-950 bg-[#f3f3f1]">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light">
    <meta name="description" content="@yield('description', 'Postline is a clean personal workspace for social publishing.')">
    <title>@yield('title', 'Postline')</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <script>
      // Client-side auth guard: the server gate covers the listed pages,
      // and this covers `/` (which can't be a protected prefix without
      // also matching /login). The API rejects unauthenticated calls
      // regardless — this is UX, not the security boundary.
      ;(() => {
        if (!/(?:^|;\s*)auth-token=/.test(document.cookie))
          window.location.replace('/login')
      })()
    </script>
    <script>
      // Cookie → bearer bridge. bun-router's Auth middleware reads the
      // Authorization header, but the page gate stores the token in the
      // auth-token cookie. Attach it to same-origin /api/ fetches so every
      // page script's plain fetch() authenticates without per-call plumbing.
      // (Previously done in the framework dev proxy; re-homed to app code
      // now that the framework is a node_modules dependency.)
      ;(() => {
        const nativeFetch = window.fetch.bind(window)
        const readToken = () => document.cookie.match(/(?:^|;\s*)auth-token=([^;]+)/)?.[1]
        window.fetch = (input, init = {}) => {
          try {
            const url = typeof input === 'string' ? input : input?.url || ''
            const sameOriginApi = url.startsWith('/api/') || url.startsWith(`${window.location.origin}/api/`)
            const token = readToken()
            if (sameOriginApi && token) {
              const headers = new Headers(init.headers || (typeof input !== 'string' ? input.headers : undefined))
              if (!headers.has('authorization')) headers.set('authorization', `Bearer ${decodeURIComponent(token)}`)
              return nativeFetch(input, { ...init, headers })
            }
          } catch {}
          return nativeFetch(input, init)
        }
      })()
    </script>
    <script>
      ;(() => {
        document.documentElement.setAttribute('data-theme', 'light')
        document.documentElement.classList.remove('dark')
        try {
          window.localStorage?.setItem('theme', 'light')
          const sidebarCollapsed = window.localStorage?.getItem('postline.sidebar.collapsed') === 'true'
          document.documentElement.classList.toggle('postline-sidebar-collapsed', sidebarCollapsed)
          document.documentElement.dataset.stxSidebarCollapsed = sidebarCollapsed ? 'true' : 'false'
          document.documentElement.style.setProperty('--postline-sidebar-width', sidebarCollapsed ? '0px' : '286px')
        } catch {}
      })()
    </script>
    <script>window.STX_ROUTER_OPTIONS = { container: '[data-postline-workspace]', viewTransitions: false };</script>
    <style>
      :root {
        color-scheme: light;
        background: #f3f3f1;
      }

      @property --postline-sidebar-width {
        syntax: '<length>';
        inherits: true;
        initial-value: 286px;
      }

      [data-postline-shell] {
        transition-property: --postline-sidebar-width;
        transition-duration: 220ms;
        transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
      }

      html.has-native-sidebar,
      html.has-native-sidebar body {
        background: transparent !important;
      }

      html.has-native-sidebar [data-postline-sidebar] {
        background-color: rgba(246, 246, 244, 0.18) !important;
        -webkit-backdrop-filter: blur(24px) saturate(1.08);
        backdrop-filter: blur(24px) saturate(1.08);
      }

      html.postline-sidebar-collapsed [data-postline-content-shell],
      html.has-native-sidebar [data-postline-content-shell],
      html.has-native-sidebar [data-postline-workspace] {
        background: #f3f3f1 !important;
      }

      html.postline-sidebar-collapsed [data-postline-workspace] {
        border-top-left-radius: 0 !important;
        border-left-color: transparent !important;
        box-shadow: none !important;
      }

      html.postline-sidebar-collapsed [data-postline-sidebar] {
        overflow: visible;
        pointer-events: none;
      }

      html.postline-sidebar-collapsed [data-shell-controls-row] {
        display: none !important;
      }

      [data-sidebar-expand-fab] {
        opacity: 0;
        transform: translate3d(-6px, 0, 0) scale(0.94);
        pointer-events: none;
        transition:
          opacity 220ms cubic-bezier(0.22, 1, 0.36, 1),
          transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      html.postline-sidebar-collapsed:not(.has-native-sidebar) [data-sidebar-expand-fab] {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1);
        pointer-events: auto;
      }

      @media (max-width: 1023px) {
        [data-sidebar-expand-fab] {
          display: none;
        }
      }

      [data-postline-app] :is(a, button, [role='button']):focus-visible {
        outline: 2px solid rgb(82 82 91 / 0.6);
        outline-offset: 2px;
      }
    </style>
    <link rel="stylesheet" href="/assets/styles/postline-toast.css">
    <link rel="stylesheet" href="/assets/styles/postline-timeline.css">
  </head>
  <body class="min-h-screen min-w-80 antialiased font-sans text-neutral-950 bg-[#f3f3f1]">
    <div class="grid grid-cols-1 grid-rows-[auto_minmax(0,1fr)] lg:grid-cols-[var(--postline-sidebar-width,286px)_minmax(0,1fr)] lg:grid-rows-1 min-h-screen duration-200 ease-out transition-[grid-template-columns]" data-postline-app data-postline-shell>
      <PostlineSidebar />

      <div class="relative min-w-0 bg-[#f3f3f1]" data-postline-content-shell>
        <button
          class="inline-flex fixed left-3.5 top-3.5 z-[90] items-center justify-center h-9 w-9 text-zinc-700 hover:text-zinc-900 bg-white/95 hover:bg-white border border-zinc-200/90 rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-zinc-400/60 shadow-[0_8px_28px_rgba(24,31,42,0.12)] backdrop-blur-sm"
          type="button"
          aria-label="Expand sidebar"
          title="Expand sidebar"
          data-sidebar-expand-fab
          data-no-window-drag
        >
          <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true"><path fill-rule="evenodd" d="M4.75 4a.75.75 0 0 0-.75.75v10.5c0 .414.336.75.75.75h2.5a.75.75 0 0 0 0-1.5H5.5V5.5h7.69l-1.22-1.22a.75.75 0 1 1 1.06-1.06l2.5 2.5a.75.75 0 0 1 0 1.06l-2.5 2.5a.75.75 0 1 1-1.06-1.06L13.19 11H5.5v5.25h1.75a.75.75 0 0 0 0 1.5h-2.5A.75.75 0 0 0 4.75 15V4.75Z" clip-rule="evenodd"/></svg>
        </button>
        <section class="overflow-hidden min-h-screen min-w-0 bg-[#f3f3f1] border-t border-zinc-200/80 lg:border-l lg:rounded-tl-[28px] lg:shadow-[-10px_0_36px_rgba(24,31,42,0.08)]" aria-label="Postline workspace" data-postline-workspace data-window-drag-region>
          <main class="p-3.5 sm:p-4 min-w-0" data-postline-router>
            @yield('content')
          </main>
        </section>
      </div>
    </div>
    <div id="postline-toast-host" class="flex bottom-6 fixed right-6 z-[100] sm:right-6 flex-col-reverse gap-2.5 max-w-[22rem] w-[calc(100%-2rem)] pointer-events-none" aria-live="polite" aria-relevant="additions"></div>
    <script type="module" src="/assets/scripts/postline-toast.ts"></script>
    <script type="module" src="/assets/scripts/postline-bluesky.ts"></script>
    <script type="module" src="/assets/scripts/postline-linkedin.ts"></script>
    <script type="module" src="/assets/scripts/postline-instagram.ts"></script>
    <script type="module" src="/assets/scripts/postline-threads.ts"></script>
    <script type="module" src="/assets/scripts/postline-social.ts"></script>
    <script type="module" src="/assets/scripts/postline-analytics.ts"></script>
    <script>
      ;(() => {
        const syncSidebarCollapse = (collapsed) => {
          const shell = document.querySelector('[data-postline-shell]')
          const sidebar = document.querySelector('[data-postline-sidebar]')
          const button = document.querySelector('[data-sidebar-collapse]')
          const collapseIcon = document.querySelector('[data-sidebar-collapse-icon]')
          const expandFab = document.querySelector('[data-sidebar-expand-fab]')

          shell?.style.setProperty('--postline-sidebar-width', collapsed ? '0px' : '286px')
          document.documentElement.style.setProperty('--postline-sidebar-width', collapsed ? '0px' : '286px')
          document.documentElement.classList.toggle('postline-sidebar-collapsed', collapsed)
          document.documentElement.dataset.stxSidebarCollapsed = collapsed ? 'true' : 'false'
          if (shell?.dataset) shell.dataset.sidebarCollapsed = collapsed ? 'true' : 'false'
          sidebar?.classList.remove('opacity-0')
          sidebar?.classList.toggle('px-5', !collapsed)
          sidebar?.classList.toggle('pt-[68px]', !collapsed)
          sidebar?.classList.toggle('pb-5', !collapsed)
          sidebar?.setAttribute('aria-hidden', String(collapsed))
          if (sidebar) {
            sidebar.style.width = collapsed ? '0px' : ''
            sidebar.style.minWidth = collapsed ? '0px' : ''
            sidebar.style.overflow = collapsed ? 'visible' : ''
          }

          document.querySelectorAll('[data-sidebar-expanded]').forEach(element => {
            element.classList.toggle('hidden', collapsed)
          })
          document.querySelectorAll('[data-sidebar-collapsible-content]').forEach(element => {
            element.classList.toggle('hidden', collapsed)
          })

          button?.setAttribute('aria-label', collapsed ? 'Expand sidebar' : 'Collapse sidebar')
          button?.setAttribute('aria-expanded', String(!collapsed))
          if (collapseIcon instanceof SVGElement)
            collapseIcon.style.transform = collapsed ? 'rotate(180deg)' : ''
          else
            collapseIcon?.classList.toggle('rotate-180', collapsed)
          expandFab?.setAttribute('aria-hidden', String(!collapsed))
          window.localStorage?.setItem('postline.sidebar.collapsed', collapsed ? 'true' : 'false')
          window.craft?.window?.setWebSidebarCollapsed?.(collapsed).catch?.(() => {})
          syncNativeShell()
        }

        const bindSidebarCollapse = () => {
          const initial = window.localStorage?.getItem('postline.sidebar.collapsed') === 'true'
          syncSidebarCollapse(initial)

          document.querySelectorAll('[data-sidebar-collapse]').forEach(button => {
            if (button.dataset.bound === 'true') return
            button.dataset.bound = 'true'
            button.addEventListener('click', () => {
              const collapsed = button.getAttribute('aria-expanded') === 'true'
              syncSidebarCollapse(collapsed)
            })
          })

          document.querySelectorAll('[data-sidebar-expand-fab]').forEach(button => {
            if (button.dataset.bound === 'true') return
            button.dataset.bound = 'true'
            button.addEventListener('click', () => syncSidebarCollapse(false))
          })
        }

        const bindShellHistory = () => {
          document.querySelectorAll('[data-shell-back]').forEach(button => {
            if (button.dataset.bound === 'true') return
            button.dataset.bound = 'true'
            button.addEventListener('click', () => window.history.back())
          })
          document.querySelectorAll('[data-shell-forward]').forEach(button => {
            if (button.dataset.bound === 'true') return
            button.dataset.bound = 'true'
            button.addEventListener('click', () => window.history.forward())
          })
        }

        const isNativeShell = () =>
          document.documentElement.classList.contains('has-native-sidebar') ||
          window.craft?.__craft_bridge_loaded === true ||
          !!window.craft?.window ||
          !!window.webkit?.messageHandlers?.craft

        const syncNativeShell = () => {
          const row = document.querySelector('[data-shell-controls-row]')
          const sidebar = document.querySelector('[data-postline-sidebar]')
          if (!row || !sidebar) return
          const collapsed = window.localStorage?.getItem('postline.sidebar.collapsed') === 'true'

          if (isNativeShell()) {
            if (window.__craftWebChromeControls === true) {
              row.style.display = 'none'
              sidebar.style.paddingTop = '68px'
              return
            }

            document.querySelectorAll('[data-native-shell-control]').forEach(element => {
              element.classList.remove('hidden')
              element.style.display = ''
            })
            row.style.position = 'fixed'
            row.style.top = '16px'
            row.style.left = '88px'
            row.style.right = 'auto'
            row.style.zIndex = '80'
            sidebar.style.paddingTop = '68px'
            return
          }

          if (collapsed) {
            row.style.display = 'none'
            sidebar.style.paddingTop = '0px'
            return
          }

          document.querySelectorAll('[data-native-shell-control]').forEach(element => {
            element.classList.add('hidden')
            element.style.display = 'none'
          })
          row.style.display = ''
          row.removeAttribute('style')
          row.style.removeProperty('position')
          row.style.removeProperty('top')
          row.style.removeProperty('left')
          row.style.removeProperty('z-index')
          sidebar.style.removeProperty('padding-top')
        }

        const bindWindowDragRegions = () => {
          document.querySelectorAll('[data-window-drag-region]').forEach(region => {
            if (region.dataset.dragBound === 'true') return
            region.dataset.dragBound = 'true'
            let dragging = false
            let lastX = 0
            let lastY = 0
            let pendingX = 0
            let pendingY = 0
            let dragFrame = 0

            const flushDrag = () => {
              dragFrame = 0
              const dx = pendingX
              const dy = pendingY
              pendingX = 0
              pendingY = 0
              if (dx || dy) window.craft?.window?.moveBy?.(dx, dy).catch?.(() => {})
            }

            const stopDrag = () => {
              dragging = false
              if (dragFrame) {
                cancelAnimationFrame(dragFrame)
                flushDrag()
              }
            }

            region.addEventListener('pointerdown', event => {
              if (event.button !== 0 || !isNativeShell()) return
              if (event.target.closest('a, button, input, textarea, select, [role="button"], [data-no-window-drag]')) return
              event.preventDefault()
              dragging = true
              lastX = event.screenX
              lastY = event.screenY
              region.setPointerCapture?.(event.pointerId)
            })

            region.addEventListener('pointermove', event => {
              if (!dragging) return
              event.preventDefault()
              const dx = event.screenX - lastX
              const dy = event.screenY - lastY
              lastX = event.screenX
              lastY = event.screenY
              pendingX += dx
              pendingY += dy
              if (!dragFrame) dragFrame = requestAnimationFrame(flushDrag)
            })

            region.addEventListener('pointerup', stopDrag)
            region.addEventListener('pointercancel', stopDrag)
            region.addEventListener('lostpointercapture', stopDrag)
          })
        }

        // Number keys 1-6 jump between pages (the sidebar shows the badges).
        const bindKeyboardShortcuts = () => {
          const routes = { 1: '/', 2: '/queue', 3: '/timeline', 4: '/analytics', 5: '/accounts', 6: '/blog', 7: '/settings' }
          document.addEventListener('keydown', (event) => {
            if (event.metaKey || event.ctrlKey || event.altKey) return
            const target = event.target
            if (target instanceof HTMLElement && target.closest('input, textarea, select, [contenteditable]')) return
            const href = routes[event.key]
            if (!href || window.location.pathname === href) return
            event.preventDefault()
            const link = document.querySelector(`[data-stx-link][href="${href}"]`)
            if (link instanceof HTMLElement) link.click()
            else window.location.assign(href)
          })
        }

        bindSidebarCollapse()
        bindShellHistory()
        bindWindowDragRegions()
        bindKeyboardShortcuts()
        syncNativeShell()
        window.addEventListener('stx:load', bindShellHistory)
        window.addEventListener('stx:load', bindSidebarCollapse)
        window.addEventListener('stx:load', bindWindowDragRegions)
        window.addEventListener('stx:load', syncNativeShell)
        window.addEventListener('craft:ready', syncNativeShell)
      })()
    </script>
    @stack('scripts')
  </body>
</html>
