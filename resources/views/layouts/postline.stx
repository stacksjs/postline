<!DOCTYPE html>
<html lang="en" class="text-neutral-950 bg-[#f3f3f1]">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light">
    <meta name="description" content="@yield('description', 'Postline is a clean personal workspace for social publishing.')">
    <title>@yield('title', 'Postline')</title>
    <script>
      ;(() => {
        document.documentElement.setAttribute('data-theme', 'light')
        document.documentElement.classList.remove('dark')
        try {
          window.localStorage?.setItem('theme', 'light')
          const sidebarCollapsed = window.localStorage?.getItem('postline.sidebar.collapsed') === 'true'
          document.documentElement.classList.toggle('postline-sidebar-collapsed', sidebarCollapsed)
          document.documentElement.dataset.stxSidebarCollapsed = sidebarCollapsed ? 'true' : 'false'
          document.documentElement.style.setProperty('--postline-sidebar-width', sidebarCollapsed ? '0px' : '286px')
        } catch {}
      })()
    </script>
    <script>window.STX_ROUTER_OPTIONS = { container: '[data-postline-workspace]', viewTransitions: false };</script>
    <style>
      :root {
        color-scheme: light;
        background: #f3f3f1;
      }

      @property --postline-sidebar-width {
        syntax: '<length>';
        inherits: true;
        initial-value: 286px;
      }

      [data-postline-shell] {
        transition-property: --postline-sidebar-width;
        transition-duration: 220ms;
        transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
      }

      html.has-native-sidebar,
      html.has-native-sidebar body {
        background: transparent !important;
      }

      html.has-native-sidebar [data-postline-sidebar] {
        background-color: rgba(246, 246, 244, 0.18) !important;
        -webkit-backdrop-filter: blur(24px) saturate(1.08);
        backdrop-filter: blur(24px) saturate(1.08);
      }

      html.has-native-sidebar [data-postline-content-shell] {
        background: #f3f3f1 !important;
      }

      html.has-native-sidebar [data-postline-workspace] {
        background: #fff !important;
      }

      html.postline-sidebar-collapsed [data-postline-content-shell],
      html.postline-sidebar-collapsed [data-postline-workspace] {
        background: #fff !important;
      }

      html.postline-sidebar-collapsed [data-postline-workspace] {
        border-top-left-radius: 0 !important;
        border-left-color: transparent !important;
        box-shadow: none !important;
      }

      html.postline-sidebar-collapsed [data-postline-workspace] > header {
        padding-left: 56px !important;
      }

      [data-postline-workspace] [data-shell-title] {
        margin: 0 !important;
        font-size: 15px !important;
        line-height: 22px !important;
        font-weight: 500 !important;
        letter-spacing: 0 !important;
      }

      html.has-native-sidebar [data-postline-workspace] > header {
        padding-left: clamp(24px, calc(var(--postline-native-title-inset, 206px) - var(--postline-sidebar-width, 0px) * 0.633), var(--postline-native-title-inset, 206px)) !important;
        transition: none !important;
      }
    </style>
  </head>
  <body class="min-h-screen min-w-80 antialiased font-sans text-neutral-950 bg-[#f3f3f1]">
    <div class="grid grid-cols-1 lg:grid-cols-[var(--postline-sidebar-width,286px)_minmax(0,1fr)] min-h-screen duration-200 ease-out transition-[grid-template-columns]" data-postline-app data-postline-shell>
      <PostlineSidebar />

      <div class="min-w-0 bg-[#f3f3f1]" data-postline-content-shell>
        <section class="overflow-hidden min-h-screen min-w-0 bg-white border-l border-t border-zinc-200/80 rounded-tl-[28px] shadow-[-10px_0_36px_rgba(24,31,42,0.08)]" aria-label="Postline workspace" data-postline-workspace>
          <header class="flex items-center justify-between px-5 lg:px-6 min-h-[56px] border-b border-zinc-200" data-window-drag-region>
            <div class="flex gap-2.5 items-center min-w-0">
              <div class="m-0 font-medium text-[15px] leading-[22px] text-zinc-900 tracking-normal truncate" role="heading" aria-level="1" data-shell-title>@yield('shell-title', 'Create Bluesky scheduler')</div>
              <button class="inline-flex items-center justify-center shrink-0 h-6 w-6 text-zinc-500 rounded-full hover:text-zinc-900 hover:bg-zinc-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-zinc-400/50 transition-colors" type="button" aria-label="More workspace actions">
                <span class="h-4 w-4 i-hugeicons-more-horizontal" aria-hidden="true"></span>
              </button>
            </div>
            <div class="flex gap-3 items-center text-zinc-500">
              <button class="hidden sm:inline-flex items-center px-3 h-9 font-medium text-sm bg-white border border-zinc-200 rounded-xl shadow-sm" type="button">Review</button>
            </div>
          </header>

          <main class="p-3.5 sm:p-4 min-w-0" data-postline-router>
            @yield('content')
          </main>
        </section>
      </div>
    </div>
    <script>
      ;(() => {
        const syncSidebarCollapse = (collapsed) => {
          const shell = document.querySelector('[data-postline-shell]')
          const sidebar = document.querySelector('[data-postline-sidebar]')
          const button = document.querySelector('[data-sidebar-collapse]')
          const collapseIcon = document.querySelector('[data-sidebar-collapse-icon]')

          shell?.style.setProperty('--postline-sidebar-width', collapsed ? '0px' : '286px')
          document.documentElement.style.setProperty('--postline-sidebar-width', collapsed ? '0px' : '286px')
          document.documentElement.classList.toggle('postline-sidebar-collapsed', collapsed)
          document.documentElement.dataset.stxSidebarCollapsed = collapsed ? 'true' : 'false'
          if (shell?.dataset) shell.dataset.sidebarCollapsed = collapsed ? 'true' : 'false'
          sidebar?.classList.remove('opacity-0', 'pointer-events-none')
          sidebar?.classList.toggle('px-5', !collapsed)
          sidebar?.classList.toggle('pt-[68px]', !collapsed)
          sidebar?.classList.toggle('pb-5', !collapsed)
          sidebar?.setAttribute('aria-hidden', String(collapsed))
          if (sidebar) sidebar.style.width = collapsed ? '0px' : ''
          if (sidebar) sidebar.style.overflow = collapsed ? 'visible' : ''

          document.querySelectorAll('[data-sidebar-expanded]').forEach(element => {
            element.classList.toggle('hidden', collapsed)
          })
          document.querySelectorAll('[data-sidebar-collapsible-content]').forEach(element => {
            element.classList.toggle('hidden', collapsed)
          })

          button?.setAttribute('aria-label', collapsed ? 'Expand sidebar' : 'Collapse sidebar')
          button?.setAttribute('aria-expanded', String(!collapsed))
          collapseIcon?.classList.toggle('rotate-180', collapsed)
          window.localStorage?.setItem('postline.sidebar.collapsed', collapsed ? 'true' : 'false')
          window.craft?.window?.setWebSidebarCollapsed?.(collapsed).catch?.(() => {})
          syncNativeShell()
        }

        const bindSidebarCollapse = () => {
          document.querySelectorAll('[data-sidebar-collapse]').forEach(button => {
            if (button.dataset.bound === 'true') return
            button.dataset.bound = 'true'
            const initial = window.localStorage?.getItem('postline.sidebar.collapsed') === 'true'
            syncSidebarCollapse(initial)
            button.addEventListener('click', () => {
              const collapsed = button.getAttribute('aria-expanded') === 'true'
              syncSidebarCollapse(collapsed)
            })
          })
        }

        const bindShellHistory = () => {
          document.querySelectorAll('[data-shell-back]').forEach(button => {
            if (button.dataset.bound === 'true') return
            button.dataset.bound = 'true'
            button.addEventListener('click', () => window.history.back())
          })
          document.querySelectorAll('[data-shell-forward]').forEach(button => {
            if (button.dataset.bound === 'true') return
            button.dataset.bound = 'true'
            button.addEventListener('click', () => window.history.forward())
          })
        }

        const isNativeShell = () =>
          document.documentElement.classList.contains('has-native-sidebar') ||
          window.craft?.__craft_bridge_loaded === true ||
          !!window.craft?.window ||
          !!window.webkit?.messageHandlers?.craft

        const syncNativeShell = () => {
          const row = document.querySelector('[data-shell-controls-row]')
          const sidebar = document.querySelector('[data-postline-sidebar]')
          const workspace = document.querySelector('[data-postline-workspace]')
          const header = workspace?.querySelector('header')
          if (!row || !sidebar) return
          const collapsed = window.localStorage?.getItem('postline.sidebar.collapsed') === 'true'

          const syncTitleInset = () => {
            if (!header || !workspace) return

            if (!isNativeShell() || !collapsed || row.style.display === 'none') {
              header.style.removeProperty('--postline-native-title-inset')
              return
            }

            const rowRight = row.getBoundingClientRect().right
            const workspaceLeft = workspace.getBoundingClientRect().left
            const inset = Math.max(48, Math.ceil(rowRight - workspaceLeft + 22))
            header.style.setProperty('--postline-native-title-inset', `${inset}px`)
          }

          if (isNativeShell()) {
            if (window.__craftWebChromeControls === true) {
              row.style.display = 'none'
              sidebar.style.paddingTop = '68px'
              syncTitleInset()
              return
            }

            document.querySelectorAll('[data-native-shell-control]').forEach(element => {
              element.classList.remove('hidden')
              element.style.display = ''
            })
            row.style.position = 'fixed'
            row.style.top = '16px'
            row.style.left = '88px'
            row.style.right = 'auto'
            row.style.zIndex = '80'
            sidebar.style.paddingTop = '68px'
            syncTitleInset()
            return
          }

          if (collapsed) {
            row.style.position = 'fixed'
            row.style.top = '14px'
            row.style.left = '14px'
            row.style.right = 'auto'
            row.style.zIndex = '80'
            sidebar.style.paddingTop = '0px'
            syncTitleInset()
            return
          }

          document.querySelectorAll('[data-native-shell-control]').forEach(element => {
            element.classList.add('hidden')
            element.style.display = 'none'
          })
          row.removeAttribute('style')
          row.style.removeProperty('display')
          row.style.removeProperty('position')
          row.style.removeProperty('z-index')
          sidebar.style.removeProperty('padding-top')
          syncTitleInset()
        }

        const bindWindowDragRegions = () => {
          document.querySelectorAll('[data-window-drag-region]').forEach(region => {
            if (region.dataset.dragBound === 'true') return
            region.dataset.dragBound = 'true'
            let dragging = false
            let lastX = 0
            let lastY = 0
            let pendingX = 0
            let pendingY = 0
            let dragFrame = 0

            const flushDrag = () => {
              dragFrame = 0
              const dx = pendingX
              const dy = pendingY
              pendingX = 0
              pendingY = 0
              if (dx || dy) window.craft?.window?.moveBy?.(dx, dy).catch?.(() => {})
            }

            const stopDrag = () => {
              dragging = false
              if (dragFrame) {
                cancelAnimationFrame(dragFrame)
                flushDrag()
              }
            }

            region.addEventListener('pointerdown', event => {
              if (event.button !== 0 || !isNativeShell()) return
              if (event.target.closest('a, button, input, textarea, select, [role="button"], [data-no-window-drag]')) return
              event.preventDefault()
              dragging = true
              lastX = event.screenX
              lastY = event.screenY
              region.setPointerCapture?.(event.pointerId)
            })

            region.addEventListener('pointermove', event => {
              if (!dragging) return
              event.preventDefault()
              const dx = event.screenX - lastX
              const dy = event.screenY - lastY
              lastX = event.screenX
              lastY = event.screenY
              pendingX += dx
              pendingY += dy
              if (!dragFrame) dragFrame = requestAnimationFrame(flushDrag)
            })

            region.addEventListener('pointerup', stopDrag)
            region.addEventListener('pointercancel', stopDrag)
            region.addEventListener('lostpointercapture', stopDrag)
          })
        }

        bindSidebarCollapse()
        bindShellHistory()
        bindWindowDragRegions()
        syncNativeShell()
        window.addEventListener('stx:load', bindShellHistory)
        window.addEventListener('stx:load', bindSidebarCollapse)
        window.addEventListener('stx:load', bindWindowDragRegions)
        window.addEventListener('stx:load', syncNativeShell)
        window.addEventListener('craft:ready', syncNativeShell)
      })()
    </script>
    @stack('scripts')
  </body>
</html>
